# Supabase
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_SECRET_KEY=

# Mapbox
NUXT_PUBLIC_MAPBOX_TOKEN=

# Stripe
NUXT_STRIPE_SECRET_KEY=
NUXT_STRIPE_WEBHOOK_SECRET=

# Resend (email delivery)
NUXT_RESEND_API_KEY=

# Pro JWT signing (RS256) — generate with: openssl genrsa -out private.pem 2048
# Then: openssl rsa -in private.pem -pubout -out public.pem
# Paste the full PEM content (with newlines as \n or use multiline env var)
NUXT_PRO_JWT_PRIVATE_KEY=

# Admin — secret for /api/admin/grant-pro (generate a random string)
NUXT_ADMIN_SECRET=

# Cron — bearer token required by /api/tasks/ingest-weather.
# Generate with: openssl rand -hex 32
# Set in Vercel env vars AND as the CRON_SECRET GitHub Actions repo secret
# so both the Vercel daily fallback and the 15-min GH Actions workflow
# authenticate. If unset, the endpoint is open (dev/local only).
CRON_SECRET=
