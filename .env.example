# Supabase
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_SECRET_KEY=

# Mapbox
NUXT_PUBLIC_MAPBOX_TOKEN=

# Stripe
NUXT_STRIPE_SECRET_KEY=
NUXT_STRIPE_WEBHOOK_SECRET=

# Resend (email delivery)
NUXT_RESEND_API_KEY=

# Pro JWT signing (RS256) — generate with: openssl genrsa -out private.pem 2048
# Then: openssl rsa -in private.pem -pubout -out public.pem
# Paste the full PEM content (with newlines as \n or use multiline env var)
NUXT_PRO_JWT_PRIVATE_KEY=
